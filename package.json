{
  "name": "sofka",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:frontend": "npx cucumber-js",
    "test:backend": "npx cucumber-js -p api",
    "test:all": "npm run test:frontend && npm run test:backend",
    "report:generate:frontend": "allure generate allure-results --clean -o allure-report",
    "report:generate:backend": "allure generate allure-results-api --clean -o allure-report",
    "report:generate:all": "allure generate allure-results allure-results-api --clean -o allure-report",
    "report:open": "allure open allure-report",
    "run:ui": "npm run test:frontend && npm run report:generate:frontend && npm run report:open",
    "run:api": "npm run test:backend && npm run report:generate:backend && npm run report:open",
    "run:all": "npm run test:all && npm run report:generate:all && npm run report:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "ts-node": "^10.9.2"
  }
}
